{
  "name": "hoopfest",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "clean": "rm -rf android ios",
    "start:android": "npx expo run:android --device",
    "start:ios": "npx expo run:ios",
    "build:ios:develop": "eas build --platform ios --clear-cache  --profile develop --local",
    "build:ios:stage": "eas build --platform ios --clear-cache --profile stage --local",
    "build:ios:main": "eas build --platform ios --clear-cache  --profile main --local",
    "build:android:develop": "eas build --platform android --clear-cache  --profile develop --local",
    "build:android:stage": "eas build --platform android --clear-cache  --profile stage --local",
    "build:android:main": "eas build --platform android --clear-cache  --profile main --local",
    "build:android:main:simulator": "eas build --platform android --clear-cache  --profile main:simulator --local",
    "build:all": "eas build --platform all --clear-cache  --profile develop --local",
    "lint": "eslint . --fix",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "expo": "^54.0.31",
    "expo-asset": "~12.0.12",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.10",
    "expo-screen-orientation": "~9.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "geolib": "^3.3.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "babel-plugin-dotenv": "^0.1.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "inquirer": "^12.6.3",
    "react-native-svg-transformer": "^1.5.1"
  },
  "private": true
}
