{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["./"],
      "@components/*": ["./src/components/*"],
      "@pages/*": ["./src/pages/*"],
      "@utils/*": ["./utils/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@services/*": ["./services/*"],
      "@stores/*": ["./src/stores/*"],
      "@router/*": ["./src/router/*"],
      "@assets/*": ["./src/assets/*"],
      "@constants/*": ["./src/constants/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}